{
  "name": "pvm-counter",
  "version": "0.1.0",
  "description": "PVM deployment of the Counter contract using Hardhat + resolc (Solidity to PolkaVM)",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network localNode",
    "deploy:testnet": "npx hardhat run scripts/deploy.ts --network polkadotTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@parity/hardhat-polkadot": "0.2.7",
    "@parity/resolc": "1.0.0"
  }
}
